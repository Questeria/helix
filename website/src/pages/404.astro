---
import Base from "../layouts/Base.astro";
---
<Base
  title="404 — Helix"
  description="Page not found."
>
  <section class="page-hero dark">
    <div class="wrap">
      <span class="eyebrow">trap 404 · page not found</span>
      <h1>This address fails <em>loud</em>, not silent.</h1>
      <p class="lede">No page at this path. In the spirit of the project: an explicit error beats a quiet wrong answer.</p>
      <div class="btn-row">
        <a class="btn btn-primary" href="/">Back to the overview <span class="arrow">→</span></a>
        <a class="btn btn-ghost" href="/verify/">See the verified run</a>
      </div>
    </div>
  </section>
</Base>
