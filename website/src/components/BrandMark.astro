---
// The Helix logo: the "299 B" graphite squircle badge (the byte count of
// hex0, the hand-typed trust root). Digits follow the current text color;
// ring and unit step down through the theme's muted tones, so the mark
// adapts to light and dark sections automatically.
---
<svg class="nav-brand-mark" viewBox="2.5 9 43 30" fill="none" aria-hidden="true">
  <rect x="4.5" y="11" width="39" height="26" rx="9" stroke="var(--fg-mute)" stroke-width="2.4"/>
  <text x="24" y="28.5" text-anchor="middle" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="13" font-weight="700" fill="currentColor">299<tspan dx="2" font-size="9.5" font-weight="600" fill="var(--fg-soft)">B</tspan></text>
</svg>
