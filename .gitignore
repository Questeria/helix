# Build outputs
/build/
/target/
*.o
*.so
*.dll
*.exe
*.a

# Stage outputs (generated binaries — keep .hex source, regenerate .bin)
# We DO track stage0/hex0/hex0.bin because it's the audited shipped artifact
stage*/build/
*.fromhex.bin
disasm.txt

# Test temp dirs
kovc/tests/_tmp/
helixc/tests/_tmp/

# Demo / scratch CLI binaries (generated by `python -m helixc.backend.x86_64`)
_demo.bin
/_*.bin

# Server-generated source files (seed-substituted Helix sources)
helixc/examples/_qlearn_compiled.hx
helixc/examples/_*_compiled.hx

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Trained model artifacts (large; tracked separately or by hash manifest)
*.safetensors
*.bin.weights
*.gguf
/checkpoints/
/data/raw/
/data/cache/

# Logs
*.log
/runs/
/.stage31-logs/
/.stage31-bin/
/.stage31-venv/
/.stage33-logs/

