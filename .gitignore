# Build outputs
/build/
/target/
*.o
*.so
*.dll
*.exe
*.a

# Stage outputs (generated binaries — keep .hex source, regenerate .bin)
# We DO track stage0/hex0/hex0.bin because it's the audited shipped artifact
stage*/build/
*.fromhex.bin
disasm.txt

# Test temp dirs
kovc/tests/_tmp/
helixc/tests/_tmp/

# T1 DDC fenced Python-helixc witness (verification only — NEVER committed).
# Restored from tag v0-pre-k4-full-with-python; the shipped tree must keep
# exactly ONE committed .py (verification/oracle/oracle_train.py). This dir
# holds the uncommitted second-witness compiler + its build/run scratch.
verification/py_witness/

# Demo / scratch CLI binaries (generated by `python -m helixc.backend.x86_64`)
_demo.bin
/_*.bin

# Server-generated source files (seed-substituted Helix sources)
helixc/examples/_qlearn_compiled.hx
helixc/examples/_*_compiled.hx

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Trained model artifacts (large; tracked separately or by hash manifest)
*.safetensors
*.bin.weights
*.gguf
/checkpoints/
/data/raw/
/data/cache/

# Generated trust attestations (produced by scripts/gpt2_demo_attest.sh; a fresh
# attestation is regenerated per run -- the script + the gates it composes are the
# committed artifacts, not the emitted attestation).
/attestation/

# Logs
*.log
/runs/
/.stage31-logs/
/.stage31-bin/
/.stage31-venv/
/.stage33-logs/

# --- public-repo hygiene: never commit secrets / local scratch ---
*.env
api.env
.env
*.key
*.pem
*.p12
*.pfx
*credentials*
id_rsa*
.loop_resume.md
__pycache__/
*.pyc
init_weights.bin
*.ptx
# T2/M0: the committed sm_86 GPU-PTX regression baseline IS tracked (the gate
# cmp's the re-minted PTX against it). All OTHER .ptx (transient emitter dumps)
# stay ignored.
!helixc/examples/*.ref.ptx
loss_curve.csv
oracle_curve.csv
